Authorization: Bearer {{token1}}

### 49. 用户1尝试删除用户2的评论（应失败 - 权限不足）
# @name deleteOtherUserComment
DELETE {{baseUrl}}/comment/2
Authorization: Bearer {{token1}}

### 50. 删除不存在的评论（应失败）
# @name deleteCommentNotFound
DELETE {{baseUrl}}/comment/999999
Authorization: Bearer {{token1}}

### 51. 重复删除已删除的评论（应失败）
# @name deleteCommentAgain
DELETE {{baseUrl}}/comment/1
Authorization: Bearer {{token1}}

### 52. 未登录删除评论（应失败）
# @name deleteCommentWithoutAuth
DELETE {{baseUrl}}/comment/2

