####################
# 社团和活动模块测试
####################

@baseUrl = http://localhost:8080/api/v1

### 1. 注册第一个测试用户（社团创建者）
# @name user1Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "club_creator_001",
  "password": "123456",
  "nickname": "社团创建者001",
  "email": "creator001@campuslink.com",
  "phone": "13900001001",
  "schoolId": 1,
  "role": "student"
}

### 手动设置第一个用户的token
@user1Token =eyJhbGciOiJIUzI1NiJ9.eyJyb2xlIjoic3R1ZGVudCIsInVzZXJJZCI6NDgsInVzZXJuYW1lIjoiMjE2NDYwMTIxMiIsImlhdCI6MTc2MzAyMzk5NSwiZXhwIjoxNzYzMDMxMTk1fQ.GbhuY0KQRe3x0cJqK4Cx9t80kQm1ugYwJRf7N6JZjVg

