### CampusLink API 测试文件
### 使用方法：
### 1. 安装 VS Code 插件 "REST Client"
### 2. 点击每个请求上方的 "Send Request" 执行
### 3. 按顺序测试，变量会自动提取

@baseUrl = http://localhost:8080/api/v1

####################
# 快速开始 - 推荐按此顺序测试
####################

### ✅ 步骤1: 健康检查
GET {{baseUrl}}/health


### ✅ 步骤2: 注册新用户
# @name register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "testquser1",
  "password": "123456",
  "nickname": "测试用户",
  "email": "t1e1st@campuslink.com",
  "phone": "13801238000",
  "schoolId": 1,
  "role": "student"
}


### ✅ 步骤3: 使用注册返回的 Token 获取当前用户信息
@token = {{register.response.body.data.token}}

GET {{baseUrl}}/user/me
Authorization: Bearer {{token}}


### ✅ 步骤4: 登录（使用用户名）
# @name loginByUsername
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "testuser",
  "password": "123456"
}


### ✅ 步骤5: 登录（使用邮箱）
# @name loginByEmail
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "test@campuslink.com",
  "password": "123456"
}


### ✅ 步骤6: 登录（使用手机号）
# @name loginByPhone
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "13800138000",
  "password": "123456"
}


### ✅ 步骤7: 刷新 Token
@refreshToken = {{loginByUsername.response.body.data.refreshToken}}

POST {{baseUrl}}/auth/refresh
Refresh-Token: {{refreshToken}}


### ✅ 步骤8: 退出登录
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{token}}


####################
# 资源模块测试
####################

### 📚 资源-1: 上传资源
# @name uploadResource
POST {{baseUrl}}/resource/upload
Authorization: Bearer {{register.response.body.data.token}}
Content-Type: application/json

{
  "title": "数据结构课件-第一章",
  "description": "数据结构与算法课程第一章课件，包含线性表、栈、队列等内容",
  "fileUrl": "https://campuslink.oss-cn-hangzhou.aliyuncs.com/resources/data-structure-ch1.pdf",
  "fileName": "数据结构-第一章.pdf",
  "fileSize": 2048576,
  "fileType": "pdf",
  "category": "courseware",
  "courseName": "数据结构与算法",
  "schoolId": 1,
  "score": 5
}


### 📚 资源-2: 获取资源列表（游客可访问）
GET {{baseUrl}}/resource/list?page=1&pageSize=10


### 📚 资源-3: 获取资源列表（按分类筛选）
GET {{baseUrl}}/resource/list?category=courseware&page=1&pageSize=10


### 📚 资源-4: 搜索资源（游客可访问）
GET {{baseUrl}}/resource/search?q=数据结构&page=1&pageSize=10


### 📚 资源-5: 获取资源详情
GET {{baseUrl}}/resource/1
Authorization: Bearer {{register.response.body.data.token}}


### 📚 资源-6: 下载资源
POST {{baseUrl}}/resource/1/download
Authorization: Bearer {{register.response.body.data.token}}


### 📚 资源-7: 点赞资源
POST {{baseUrl}}/resource/1/like
Authorization: Bearer {{register.response.body.data.token}}


### 📚 资源-8: 取消点赞
DELETE {{baseUrl}}/resource/1/like
Authorization: Bearer {{register.response.body.data.token}}


####################
# 错误测试
####################

### ❌ 登录失败 - 密码错误
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "testuser",
  "password": "wrong_password"
}


### ❌ 登录失败 - 用户不存在
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "account": "nonexistent_user",
  "password": "123456"
}


### ❌ 注册失败 - 用户名已存在
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "password": "123456",
  "nickname": "重复用户",
  "email": "duplicate@campuslink.com",
  "phone": "13700137000"
}


### ❌ 注册失败 - 邮箱已存在
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "testuser2",
  "password": "123456",
  "nickname": "测试用户2",
  "email": "test@campuslink.com",
  "phone": "13700137001"
}


### ❌ 未授权访问 - 没有 Token
GET {{baseUrl}}/user/me


### ❌ 未授权访问 - 无效 Token
GET {{baseUrl}}/user/me
Authorization: Bearer invalid_token_here


####################
# 参数校验测试
####################

### ❌ 用户名太短（少于3个字符）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "ab",
  "password": "123456",
  "nickname": "测试",
  "email": "test1@campuslink.com"
}


### ❌ 用户名包含特殊字符
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "test@user",
  "password": "123456",
  "nickname": "测试",
  "email": "test2@campuslink.com"
}


### ❌ 密码太短（少于6个字符）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "testuser3",
  "password": "123",
  "nickname": "测试",
  "email": "test3@campuslink.com"
}


### ❌ 邮箱格式错误
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "testuser4",
  "password": "123456",
  "nickname": "测试",
  "email": "invalid-email-format"
}


### ❌ 手机号格式错误
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "testuser5",
  "password": "123456",
  "nickname": "测试",
  "email": "test5@campuslink.com",
  "phone": "12345678901"
}


