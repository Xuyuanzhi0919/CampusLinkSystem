####################
# 任务模块测试
####################

@baseUrl = http://localhost:8080/api/v1

### 1. 注册发布者账号
# @name taskPublisher
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "task_publisher_007",
  "password": "123456",
  "nickname": "任务发布者",
  "email": "publisher@campuslink.com",
  "phone": "13800010005",
  "schoolId": 1,
  "role": "student"
}

### 2. 注册接单者账号
# @name taskAccepter
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "task_accepter_007",
  "password": "123456",
  "nickname": "任务接单者",
  "email": "acceter@campuslink.com",
  "phone": "13800000302",
  "schoolId": 1,
  "role": "student"
}

### 手动设置token（从上面的注册响应中复制）
