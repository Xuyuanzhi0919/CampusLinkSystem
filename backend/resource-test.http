Content-Type: application/json
Authorization: Bearer {{uploaderToken}}

{
  "title": "测试拒绝流程资源",
  "description": "这个资源将被管理员拒绝",
  "fileUrl": "https://campuslink-oss.example.com/resources/reject-test.pdf",
  "fileName": "reject-test.pdf",
  "fileSize": 1024000,
  "fileType": "pdf",
  "category": "其他",
