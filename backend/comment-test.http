####################
# 评论模块测试
####################

@baseUrl = http://localhost:8080/api/v1

### 1. 注册测试用户1（评论者1）
# @name commentUser1
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "comment_user_001",
  "password": "123456",
  "nickname": "评论测试用户1",
  "email": "comment001@campus.com",
  "phone": "13900830041",
  "schoolId": 1,
  "role": "student"
}

