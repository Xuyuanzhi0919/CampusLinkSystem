### 21. 注册 - 用户名已存在
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "password": "123456",
  "nickname": "测试2",
  "email": "test6@campuslink.com",
  "phone": "13800138005"
}


####################
# 完整流程测试
####################

### 22. 完整流程 - 注册
# @name register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "workflow_test",
  "password": "123456",
  "nickname": "流程测试",
  "email": "workflow@campuslink.com",
  "phone": "13600136000",
  "schoolId": 1,
  "role": "student"
}

### 23. 完整流程 - 使用注册返回的 Token 获取用户信息
@workflowToken = {{register.response.body.data.token}}

GET {{baseUrl}}/user/me
Content-Type: application/json
Authorization: Bearer {{workflowToken}}

### 24. 完整流程 - 使用 RefreshToken 刷新
# @name refresh
@workflowRefreshToken = {{register.response.body.data.refreshToken}}

POST {{baseUrl}}/auth/refresh
Content-Type: application/json
Refresh-Token: {{workflowRefreshToken}}

### 25. 完整流程 - 使用新 Token 获取用户信息
@newToken = {{refresh.response.body.data.token}}

GET {{baseUrl}}/user/me
Content-Type: application/json
Authorization: Bearer {{newToken}}
